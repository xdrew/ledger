# Local development defaults ONLY. Real deployments inject these via the
# environment / secrets (see docs). No production secrets belong in this file.
APP_ENV=dev
APP_DEBUG=1
APP_SECRET=local_dev_not_a_secret
LOG_LEVEL=info

# Host is the compose service name "postgres"; everything runs inside Docker.
DATABASE_URL="postgresql://ledger:ledger@postgres:5432/ledger?serverVersion=18&charset=utf8"
