# Local development defaults ONLY. Real deployments inject these via the
# environment / secrets (see docs). No production secrets belong in this file.
APP_ENV=dev
APP_DEBUG=1
APP_SECRET=local_dev_not_a_secret
LOG_LEVEL=info

# Retention for completed idempotency keys (seconds; default 24h).
IDEMPOTENCY_TTL_SECONDS=86400

# Static API key for the HTTP API (X-Api-Key header). Local-dev default only;
# real deployments inject a strong key via the environment.
API_KEY=local_dev_api_key

# Readiness: max age (seconds) of the outbox relay heartbeat before /readyz fails.
READINESS_RELAY_MAX_AGE=30

# Distributed tracing (OpenTelemetry). Off by default. When enabled, spans export
# over OTLP/HTTP to OTEL_EXPORTER_OTLP_ENDPOINT (empty → in-memory, for local dev).
OTEL_TRACING_ENABLED=0
OTEL_EXPORTER_OTLP_ENDPOINT=

# Natural-language statement queries (?q= on the statement endpoint). Off by
# default; needs a real ANTHROPIC_API_KEY (injected via the environment, never
# committed). LLM_MODEL is the operator's explicit cost/latency choice.
LLM_STATEMENT_QUERY_ENABLED=0
ANTHROPIC_API_KEY=
LLM_MODEL=claude-opus-4-8

# Host is the compose service name "postgres"; everything runs inside Docker.
DATABASE_URL="postgresql://ledger:ledger@postgres:5432/ledger?serverVersion=18&charset=utf8"

# Host port for the RoadRunner HTTP service (container always listens on 8080).
HTTP_HOST_PORT=8080
