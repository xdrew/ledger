{
    "name": "ledger/ledger-core",
    "description": "Event-sourced payment ledger — backend core.",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.5",
        "ext-pdo": "*",
        "baldinof/roadrunner-bundle": "^3.3",
        "doctrine/dbal": "^4.0",
        "doctrine/doctrine-bundle": "^3.2",
        "doctrine/doctrine-migrations-bundle": "^4.0",
        "google/protobuf": "^4.31.1",
        "nyholm/psr7": "^1.8",
        "open-telemetry/exporter-otlp": "^1.4",
        "open-telemetry/sdk": "^1.14",
        "ramsey/uuid": "^4.7",
        "spiral/roadrunner-metrics": "^3.3",
        "symfony/console": "^8.0",
        "symfony/dotenv": "^8.0",
        "symfony/framework-bundle": "^8.0",
        "symfony/http-client": "^8.1",
        "symfony/monolog-bundle": "^4.0",
        "symfony/property-access": "^8.0",
        "symfony/psr-http-message-bridge": "^8.1",
        "symfony/runtime": "^8.0",
        "symfony/security-bundle": "^8.0",
        "symfony/serializer": "^8.0",
        "symfony/validator": "^8.0",
        "symfony/yaml": "^8.0",
        "thesis/message-bus": "^0.5@dev"
    },
    "require-dev": {
        "bamarni/composer-bin-plugin": "^1.8",
        "symfony/browser-kit": "^8.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "symfony/runtime": true,
            "php-http/discovery": true,
            "bamarni/composer-bin-plugin": true
        },
        "sort-packages": true
    },
    "extra": {
        "bamarni-bin": {
            "bin-links": true,
            "forward-command": true,
            "target-directory": "vendor-bin"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
