{
    // Mutation testing scoped to the domain layer (brief §7.6): the pure logic
    // the unit suite covers. Infrastructure (DBAL adapters, HTTP) is exercised
    // by integration/functional tests, which mutation runs deliberately skip.
    "$schema": "vendor-bin/tools/vendor/infection/infection/resources/schema.json",
    "source": {
        "directories": [
            "src/SharedKernel",
            "src/EventStore",
            "src/Accounts/Domain",
            "src/Ledger/Domain",
            "src/Transfers/Domain",
            "src/Idempotency"
        ],
        "excludes": [
            // Thin DBAL adapters within the mutated trees — integration-tested.
            "src/EventStore/Dbal",
            "src/Idempotency/Dbal"
        ]
    },
    "timeout": 10,
    "threads": "max",
    "tmpDir": "var/cache/infection",
    "logs": {
        "text": "var/cache/infection/infection.log",
        "summary": "var/cache/infection/summary.log"
    },
    "testFramework": "phpunit",
    "testFrameworkOptions": "--testsuite=unit",
    // pcov ships disabled by default in the image; enable it for the coverage run.
    "initialTestsPhpOptions": "-d pcov.enabled=1",
    "mutators": {
        "@default": true
    }
}
