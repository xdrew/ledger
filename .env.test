# Test environment overrides. Integration tests run against a dedicated database
# so they never collide with local dev data.
APP_ENV=test
APP_DEBUG=0

DATABASE_URL="postgresql://ledger:ledger@postgres:5432/ledger_test?serverVersion=18&charset=utf8"

# NL statement queries: on in tests (served by the fake translator — no API
# calls); the flag-off path is covered by a test overriding the env var.
LLM_STATEMENT_QUERY_ENABLED=1
